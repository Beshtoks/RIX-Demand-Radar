<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rr_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="40dp"
    android:paddingEnd="16dp"
    android:paddingBottom="0dp">


        <TextView
            android:id="@+id/tvAiScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_screen_title"
            android:textColor="@color/rr_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/tvAiScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ai_screen_subtitle"
            android:textColor="@color/rr_text_secondary"
            android:textSize="14sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="vertical">

<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAiNowTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_now_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAiNowValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ai_now_value"
                android:textColor="@color/rr_green"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiNowMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/ai_now_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAiWindowTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_window_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAiWindowValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ai_window_value"
                android:textColor="@color/rr_accent_2"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiWindowMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/ai_window_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAiRiskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_risk_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAiRiskValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ai_risk_value"
                android:textColor="@color/rr_yellow"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiRiskMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/ai_risk_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAiRoutesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_routes_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAiRoutesValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ai_routes_value"
                android:textColor="@color/rr_orange"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiRoutesMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/ai_routes_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAiCommentTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_comment_title"
                android:textColor="@color/rr_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiCommentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/ai_comment_text"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAiHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="3dp"
                android:text="@string/ai_hint"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
