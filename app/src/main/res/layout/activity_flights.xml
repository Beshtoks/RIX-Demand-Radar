<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rr_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="40dp"
    android:paddingEnd="16dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/tvFlightsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Прилёты RIX"
        android:textColor="@color/rr_text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFlightsSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Расписание Šodien + Rīt"
        android:textColor="@color/rr_text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@color/rr_surface"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvFlightsBlockTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Окно: Šodien + Rīt"
                android:textColor="@color/rr_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFlightsRefresh"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="96dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Обновить"
                android:textAllCaps="false"
                android:textSize="13sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollFlightsRoot"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutFlightsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@color/rr_surface"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvFlightsHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:text="Источник: backend"
            android:textColor="@color/rr_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
