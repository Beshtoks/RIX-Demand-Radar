<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollForecastRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rr_background"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvForecastTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forecast_title"
            android:textColor="@color/rr_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvForecastSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/forecast_subtitle"
            android:textColor="@color/rr_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvForecastNowTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forecast_now_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvForecastNowValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/forecast_now_value"
                android:textColor="@color/rr_green"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForecastNowMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/forecast_now_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvForecastHour1Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forecast_hour_1_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvForecastHour1Value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/forecast_hour_1_value"
                android:textColor="@color/rr_red"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForecastHour1Meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/forecast_hour_1_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvForecastHour3Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forecast_hour_3_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvForecastHour3Value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/forecast_hour_3_value"
                android:textColor="@color/rr_yellow"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForecastHour3Meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/forecast_hour_3_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/blockForecast15Days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/rr_surface"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvForecastBestWindowTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forecast_best_window_title"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvForecastBestWindowValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/forecast_best_window_value"
                android:textColor="@color/rr_accent_2"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForecastBestWindowMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/forecast_best_window_meta"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvForecastAiTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forecast_ai_title"
                android:textColor="@color/rr_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForecastAiText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/forecast_ai_text"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvForecastHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="3dp"
                android:text="@string/forecast_hint"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
