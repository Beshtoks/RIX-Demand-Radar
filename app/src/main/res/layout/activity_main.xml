<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rr_background"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_dashboard"
            android:textColor="@color/rr_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/label_city"
            android:textColor="@color/rr_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvUpdated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/label_updated"
            android:textColor="@color/rr_text_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDataMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Режим данных: LOCAL"
            android:textColor="@color/rr_text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/cardDemand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_demand_index"
                android:textColor="@color/rr_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDemandValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_demand_value"
                android:textColor="@color/rr_green"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDemandStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/label_demand_status"
                android:textColor="@color/rr_yellow"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/cardFlights"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_flights"
                android:textColor="@color/rr_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFlight1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/flight_1"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvFlight2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/flight_2"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvFlight3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/flight_3"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_events"
                android:textColor="@color/rr_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEvent1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/event_1"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvEvent2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/event_2"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvEvent3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/event_3"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardAi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_ai"
                android:textColor="@color/rr_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/ai_text"
                android:textColor="@color/rr_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottomMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/rr_surface_2"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp"
            android:weightSum="5">

            <Button
                android:id="@+id/btnFlights"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/rr_button_ai"
                android:text="@string/button_open_flights"
                android:textAllCaps="false"
                android:textColor="@color/rr_text_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnEvents"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/rr_button_ai"
                android:text="@string/button_open_events"
                android:textAllCaps="false"
                android:textColor="@color/rr_text_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnForecast"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/rr_button_ai"
                android:text="@string/button_open_forecast"
                android:textAllCaps="false"
                android:textColor="@color/rr_text_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnMap"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/rr_button_ai"
                android:text="@string/button_open_map"
                android:textAllCaps="false"
                android:textColor="@color/rr_text_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnAi"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:backgroundTint="@color/rr_button_ai"
                android:text="@string/button_open_ai"
                android:textAllCaps="false"
                android:textColor="@color/rr_text_primary"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>